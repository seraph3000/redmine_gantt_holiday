<h2><%= l(:label_holiday_settings) %></h2>

<fieldset class="box tabular">
  <legend><%= l(:label_holiday_target_selection) %></legend>
  <%= form_tag({action: 'index'}, method: :get) do %>
    <p>
      <label><%= l(:label_holiday_calendar) %></label>
      <%= select_tag 'calendar_id', options_from_collection_for_select(@calendars, 'id', 'name', @selected_calendar_id), onchange: "this.form.submit();" %>
    </p>
    <p>
      <label><%= l(:label_holiday_target_year) %></label>
      <%= select_tag 'year', options_for_select((Date.current.year - 1)..(Date.current.year + 2), @selected_year), onchange: "this.form.submit();" %>
    </p>
  <% end %>
</fieldset>

<%= form_tag({action: 'update'}, method: :post) do %>
  <%= hidden_field_tag 'calendar_id', @selected_calendar_id %>
  <%= hidden_field_tag 'year', @selected_year %>

  <div class="autoscroll">
    <table class="list odd-even" id="holidays_table">
      <thead>
        <tr>
          <th><%= l(:label_holiday_name_optional) %></th>
          <th><%= l(:label_holiday_date) %></th>
          <th>
            <label>
            <%= check_box_tag 'toggle_all_holidays', 1, false, id: 'toggle_all_holidays', title: l(:label_holiday_enable_toggle) %>
            <%= l(:label_holiday_enable_toggle) %>
            </label>
          </th>
        </tr>
      </thead>
      <tbody>
        <% @holidays.each do |holiday| %>
          <tr style="<%= holiday.active ? '' : 'background-color: #f6f6f6;' %>">
            <td style="color: <%= holiday.active ? 'inherit' : '#999' %>;">
              <%= holiday.holiday_name.presence || l(:label_holiday_unnamed) %>
            </td>
            <td style="<%= holiday.active ? '' : 'text-decoration: line-through; color: #999;' %>">
              <%= holiday.holiday.strftime('%Y/%m/%d') %> (<%= %w(日 月 火 水 木 金 土)[holiday.holiday.wday] %>)
            </td>
            <td>
              <%= hidden_field_tag "holidays[#{holiday.id}]", '0' %>
              <%= check_box_tag "holidays[#{holiday.id}]", '1', holiday.active, class: 'holiday-checkbox' %>
            </td>
          </tr>
        <% end %>
        <tr class="new-holiday-row" style="background-color: #eaf1fb; border-top: 2px solid #337ab7;">
          <td><%= text_field_tag "new_holidays[0][name]", "", placeholder: l(:label_holiday_placeholder_name), class: "new-holiday-name" %></td>
          <td><%= date_field_tag "new_holidays[0][date]", "", class: "new-holiday-date" %></td>
          <td>
            <%= check_box_tag "new_holidays[0][check]", '1', false, class: "new-holiday-check" %>
          </td>
        </tr>
      </tbody>
    </table>
  </div>
  <p><%= submit_tag l(:button_apply) %></p>
<% end %>
<hr>
<fieldset class="box">
  <legend><%= l(:label_holiday_csv_import) %></legend>
  <%= form_tag({action: 'import_csv'}, multipart: true) do %>
    <%= hidden_field_tag 'calendar_id', @selected_calendar_id %>
    <%= hidden_field_tag 'year', @selected_year %>
    <p>
      <%= file_field_tag 'csv_file', accept: '.csv' %>
      <%= submit_tag l(:button_import) %>
    </p>
    <p class="em-info" style="font-size: 0.9em; color: #666;">
      <%= l(:text_holiday_csv_info_1) %><br>
      <%= l(:text_holiday_csv_info_2) %>
    </p>
  <% end %>
</fieldset>

<%= javascript_tag nonce: true do %>
  $(function() {
    $(document).on('change', '.new-holiday-date', function() {
      var $row = $(this).closest('.new-holiday-row');
      if ($(this).val()) {
        $row.find('.new-holiday-check').prop('checked', true);
        
        // 最終行に入力があった場合のみ新しい行を追加
        if ($row.is($('.new-holiday-row').last())) {
          var $clone = $row.clone();
          var newIndex = new Date().getTime();
          $clone.find('input').each(function() {
            var name = $(this).attr('name');
            if (name) $(this).attr('name', name.replace(/\[[0-9]+\]/, '[' + newIndex + ']'));
          });
          $clone.find('.new-holiday-name, .new-holiday-date').val('');
          $clone.find('.new-holiday-check').prop('checked', false);
          $('#holidays_table tbody').append($clone);
        }
      }
    });
  });
<% end %>
<%= javascript_tag nonce: true do %>
  $(function() {
    // 「全選択/全解除」チェックボックスがクリックされた時の処理
    $('#toggle_all_holidays').on('change', function() {
      // 自分のチェック状態（true/false）を取得
      var isChecked = $(this).is(':checked');
      
      // name属性が "holidays[" で始まるすべてのチェックボックスのON/OFFを一括切り替え
      $('input[type="checkbox"][name^="holidays["]').prop('checked', isChecked);
    });
  });
<% end %>